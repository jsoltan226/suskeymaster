cc_defaults {
    name: "suskeymaster_defaults",
    cflags: ["-Wall", "-Wextra", "-pipe", "-fPIC"],
    cppflags: ["-Wno-c11-extensions", "-std=c++20", "-fPIC", "-pipe"],
    include_dirs: [
        ".",
    ],
    local_include_dirs: [ "." ],
}

cc_library_shared {
    name: "libsuskeymaster",
    defaults: ["suskeymaster_defaults"],

    srcs: [
        "handler.cpp"
    ],

    static_libs: [
        "libcgdcore",
        "libsuscertmod",
        "libsuscertsign",
        "libcrypto_sus_prebuilt"
    ],

    shared_libs: [
        "libhidlbase",
        "libhidltransport",
        "liblog",
        "libutils",
        "android.hardware.keymaster@4.0"
    ],

    cflags: ["-g", "-O0"],
    cppflags: ["-g", "-O0"],

    visibility: [ "//visibility:public" ],

    target: {
        android_arm64: {
            enabled: true,
        },
        android_arm: {
            enabled: false,
        },
        android_x86_64: {
            enabled: true,
        },
        android_x86: {
            enabled: false,
        },
    },
}
