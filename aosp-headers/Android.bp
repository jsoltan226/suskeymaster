cc_library_headers {
    name: "suskeymaster_aosp_headers",
    host_supported: true,
    compile_multilib: "64",

    export_include_dirs: [
        "include-base",
        "include-keymaster",
    ],

    visibility: ["//visibility:public"],
    target: {
        android: { enabled: true },
        host: { enabled: true }
    }
}
