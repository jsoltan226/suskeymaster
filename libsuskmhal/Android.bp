cc_defaults {
    name: "libsuskmhal_defaults",
    cflags: ["-Wall", "-Wextra", "-pipe", "-fPIC" ],
    cppflags: ["-Wno-c11-extensions", "-std=c++20", "-fPIC", "-pipe" ],
    include_dirs: [ "." ],
    local_include_dirs: [ "." ],
}

cc_library_static {
    name: "libsuskmhal",
    host_supported: true,
    compile_multilib: "64",
    defaults: [ "libsuskmhal_defaults" ],

    srcs: [
        "*.cpp", "*.c",
        "hidl/*.cpp", "hidl/*.c",
        "util/*.cpp", "util/*.c"
    ],
    cflags: [ "-g", "-O0" ],
    cppflags: [ "-g", "-O0" ],

    export_include_dirs: [ "include" ],

    static_libs: [
        "libcgdcore",
    ],

    shared_libs: [
    ],

    header_libs: [
        "suskeymaster_aosp_headers",
    ],


    visibility: [ "//visibility:public" ],

    target: {
        host: {
            enabled: true,
            cflags: [ "-DSUSKEYMASTER_BUILD_HOST", "-USUSKEYMASTER_BUILD_ANDROID" ],
        },
        android_arm64: {
            cflags: [ "-USUSKEYMASTER_BUILD_HOST", "-DSUSKEYMASTER_BUILD_ANDROID" ],
            shared_libs: [
                "liblog",
                "libutils",
                "libhidltransport",
                "libhidlbase",
                "android.hardware.keymaster@4.0",
            ],
        },
        android_arm: { enabled: false },
        android_x86: { enabled: false },
        android_x86_64: { enabled: false }
    },
}
