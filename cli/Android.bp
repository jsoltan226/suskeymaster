cc_defaults {
    name: "suskeymaster_cli_defaults",
    cflags: ["-Wall", "-Wextra", "-pipe", "-fPIC" ],
    cppflags: ["-Wno-c11-extensions", "-std=c++20", "-fPIC", "-pipe", "-fno-exceptions", "-fno-rtti" ],
    include_dirs: [ "." ],
    local_include_dirs: [ "." ],
}

cc_binary {
    name: "suskeymaster",
    host_supported: true,
    compile_multilib: "64",
    stl: "libc++_static",

    defaults: [ "suskeymaster_cli_defaults" ],
    srcs: [
        "*.cpp", "*.c"
    ],
    cflags: [ "-g", "-O0" ],
    cppflags: [ "-g", "-O0" ],

    min_sdk_version: "28",

    static_libs: [
        "libcgdcore",
        "libsuskmhal",
        "libsuscertmod",
        "libbuiltinkeybox",
    ],

    shared_libs: [
    ],

    header_libs: [
        "suskeymaster_aosp_headers",
    ],


    visibility: [ "//visibility:public" ],

    target: {
        host: {
            enabled: true,
            cflags: [
                "-DSUSKEYMASTER_BUILD_HOST", "-USUSKEYMASTER_BUILD_ANDROID",
                "-USUSKEYMASTER_HAL_ENABLE_3_0", "-DSUSKEYMASTER_HAL_DISABLE_3_0",
                "-USUSKEYMASTER_HAL_ENABLE_4_0", "-DSUSKEYMASTER_HAL_DISABLE_4_0",
                "-USUSKEYMASTER_HAL_ENABLE_4_1", "-DSUSKEYMASTER_HAL_DISABLE_4_1",
            ],
            static_libs: [
                "liblog",
                "libcutils",
                "libbase",
                "libcrypto",
            ],
        },
        android_arm64: {
            static_executable: false,
            stl: "c++_static",

            cflags: [
                "-USUSKEYMASTER_BUILD_HOST", "-DSUSKEYMASTER_BUILD_ANDROID",
                "-DSUSKEYMASTER_HAL_ENABLE_3_0", "-USUSKEYMASTER_HAL_DISABLE_3_0",
                "-DSUSKEYMASTER_HAL_ENABLE_4_0", "-USUSKEYMASTER_HAL_DISABLE_4_0",
                "-DSUSKEYMASTER_HAL_ENABLE_4_1", "-USUSKEYMASTER_HAL_DISABLE_4_1",
            ],

            shared_libs: [
                "libdl",
            ],
            static_libs: [
                "libcrypto_sus_prebuilt",
            ],
        },
        android_arm: { enabled: false },
        android_x86: { enabled: false },
        android_x86_64: { enabled: false },

        // for windows host build, include the winsock2 library for `htonl' and 'ntohl'
        windows: { host_ldlibs: [ "-lws2_32" ] }
    },
}
